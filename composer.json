{
    "name": "akit/akit",
    "description": "Lightweight PHP 8.4 toolkit for the Anthropic API — zero production dependencies.",
    "type": "library",
    "license": "MIT",
    "keywords": ["anthropic", "claude", "ai", "llm", "api", "toolkit"],
    "homepage": "https://github.com/yourusername/akit",
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Akit\\": "src/"
        },
        "files": [
            "helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Akit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
